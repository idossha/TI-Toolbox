
# Dockerfile.freesurfer
FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# Install dependencies
RUN apt-get update && apt-get install -y \
  wget \
  bc \
  tcsh \
  libgomp1 \
  libx11-6 \
  libxt6 \
  libxext6 \
  libjpeg62 \
  libtiff5 \
  libglu1-mesa \
  perl-modules \
  libglib2.0-0 \
  libgtk2.0-0 \
  locales \
  tzdata \
  && locale-gen en_US.UTF-8 \
  && apt-get clean && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

# Download and install FreeSurfer via .deb package
RUN wget --progress=bar:force:noscroll https://surfer.nmr.mgh.harvard.edu/pub/dist/freesurfer/8.1.0/freesurfer_ubuntu22-8.1.0_amd64.deb -P /tmp \
  && apt-get install -y /tmp/freesurfer_ubuntu22-8.1.0_amd64.deb \
  && apt-get clean && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

# The .deb installs to /usr/local/freesurfer/8.1.0 — move to standard path
RUN mv /usr/local/freesurfer/8.1.0/* /usr/local/freesurfer/ && rmdir /usr/local/freesurfer/8.1.0

ENV FREESURFER_HOME=/usr/local/freesurfer

# Copy the FreeSurfer license
COPY license.txt $FREESURFER_HOME/license.txt

# Install MATLAB Runtime R2019b (v97) using FreeSurfer's own installer script
RUN /usr/local/freesurfer/bin/fs_install_mcr R2019b

# Set environment variables
ENV SUBJECTS_DIR=$FREESURFER_HOME/subjects
ENV FS_LICENSE=$FREESURFER_HOME/license.txt
ENV PATH="$FREESURFER_HOME/bin:$PATH"

CMD ["/bin/bash"]
